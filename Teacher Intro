<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vedantu Demo Suite</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Great+Vibes&family=Montserrat:wght@400;700;900&family=Nunito:wght@400;600;800&display=swap');

        body { font-family: 'Montserrat', sans-serif; background: #f0f4f8; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        
        /* Tab Navigation */
        .nav-tabs { display: flex; gap: 10px; margin-bottom: 20px; }
        .tab-btn { padding: 12px 25px; border: none; border-radius: 25px; cursor: pointer; font-weight: bold; background: #ddd; color: #555; transition: 0.3s; }
        .tab-btn.active { background: #ff4500; color: white; }

        .panel { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 500px; text-align: center; display: none; }
        .panel.active { display: block; border-top: 6px solid #ff4500; }
        
        input, select, textarea { padding: 12px; width: 92%; margin: 8px 0; border: 1.5px solid #ddd; border-radius: 8px; font-size: 14px; outline: none; }
        .btn-gen { background: #ff4500; color: #fff; padding: 15px; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; width: 95%; margin-top: 10px; }
        .btn-dl { background: #28a745; color: #fff; padding: 12px 25px; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; display: none; margin: 15px auto; }

        /* --- SLIDE CANVAS --- */
        #slidePreview { 
            display: none; width: 1024px; height: 576px; background: #fff; position: relative; overflow: hidden; margin-top: 20px;
            background-image: linear-gradient(to right, rgba(255,255,255,0.95), rgba(255,255,255,0.6)), url('https://img.freepik.com/free-vector/watercolor-back-school-background_23-2149450791.jpg');
            background-size: cover; border: 8px solid #fff; box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .content-box { position: absolute; left: 60px; top: 50px; width: 520px; text-align: left; z-index: 10; }
        .t-name { font-family: 'Great Vibes', cursive; font-size: 75px; color: #2c3e50; margin: 0; }
        .t-tag { color: #ff4500; font-weight: 800; border-bottom: 3px solid #ff4500; display: inline-block; margin-bottom: 15px; text-transform: uppercase; }
        .t-points { list-style: none; padding: 0; margin-top: 20px; }
        .t-point { display: flex; align-items: center; margin-bottom: 12px; font-weight: 700; color: #333; font-size: 18px; }
        .t-icon { background: #ff4500; color: white; width: 30px; height: 30px; border-radius: 5px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0; }

        .photo-wrap { position: absolute; right: 40px; bottom: 0; width: 400px; height: 530px; display: flex; align-items: flex-end; justify-content: center; }
        #dispImg { max-width: 100%; max-height: 100%; object-fit: contain; }
        .v-logo { position: absolute; top: 25px; right: 35px; height: 55px; opacity: 0.9; }

    </style>
</head>
<body>

    <div class="nav-tabs">
        <button id="btn1" class="tab-btn active" onclick="showMode('cert')">Certificate</button>
        <button id="btn2" class="tab-btn" onclick="showMode('teacher')">Teacher Intro</button>
    </div>

    <div id="teacherPanel" class="panel active">
        <h2 style="color:#ff4500">Teacher Intro Generator</h2>
        <div style="background:#fff5f0; padding:10px; border-radius:8px; border:1px dashed #ff4500; margin-bottom:10px;">
            <label style="font-size:12px; font-weight:bold; color:#ff4500;">Upload Teacher Photo</label>
            <input type="file" id="tPhoto" accept="image/*" style="border:none;">
        </div>
        <input type="text" id="name" placeholder="Name (e.g. Ms. Sarah)">
        <input type="text" id="exp" placeholder="Experience (e.g. 8+ Years)">
        <textarea id="intro" rows="2" placeholder="Brief intro sentence..."></textarea>
        <input type="text" id="p1" placeholder="Achievement 1">
        <input type="text" id="p2" placeholder="Achievement 2">
        <button class="btn-gen" onclick="generateSlide()">Create Intro Slide ✨</button>
    </div>

    <button id="dlBtn" class="btn-dl" onclick="download()">Download PNG 📥</button>

    <div id="slidePreview">
        <img src="https://upload.
